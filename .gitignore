node_modules/
dist/
.DS_Store
*.log

# Vite / build outputs
*.tsbuildinfo
.vite/

# Wrangler (Cloudflare Workers)
.wrangler/
.dev.vars

# Generated from node_modules at build time (rrweb-player UMD/CSS inlined for
# the Worker). Regenerated by `pnpm --filter @bugzar/backend gen:player`.
packages/backend/src/*.generated.ts

# Generated at build time (the @bugzar/viewer single-file IIFE inlined into the
# SDK's offline HTML export). Regenerated by `pnpm --filter @bugzar/sdk gen:viewer`.
packages/sdk/src/*.generated.ts
packages/viewer/dist-inline/

# .env files hold build-time secrets (Atlassian client_secret, etc.) and must
# never be committed. Each package ships a committed `.env.example` with
# placeholders; copy it to `.env` and fill in your own values locally.
.env
.env.local
.env.development
.env.production
!.env.example

# Ralph loop logs
.ralph-logs/

# IDE
.vscode/
.idea/

# Test artifacts
coverage/
playwright-report/
test-results/

# Private keys — never commit.
*.pem
*.crx
packages/backend/wrangler.local.jsonc

# npm pack artifacts (build output)
*.tgz
